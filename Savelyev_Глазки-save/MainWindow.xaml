        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Savelyev_Глазки_save"
        mc:Ignorable="d"
        Title="Глазки - save" Height="550" Width="850" MinHeight="450" MinWidth="800" FontFamily="Century Gothic" Icon="/Res/Глазки-save.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#FFE9F9">
            <Image Source="/Res/Глазки-save.png" HorizontalAlignment="Left"></Image>
            <TextBlock Text="Глазки - save" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30"></TextBlock>
            <Button Content="Назад" Name="BtnBack" HorizontalAlignment="Right" VerticalAlignment="Center" Click="BtnBack_Click"></Button>

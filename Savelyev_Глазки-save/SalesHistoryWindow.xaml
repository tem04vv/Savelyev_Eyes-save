<Window x:Class="Savelyev_Глазки_save.SalesHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Savelyev_Глазки_save"
        mc:Ignorable="d"
        Title="SalesHistoryWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Выберите товар" FontSize="20" VerticalAlignment="Top" Margin="12,0,0,0"></TextBlock>
            <ComboBox Grid.Column="0" Height="25" Width="350" Name="ProductComboBox"></ComboBox>

            <TextBlock Grid.Column="1" Text="Дата:" FontSize="20" VerticalAlignment="Top" Margin="6,0,0,0"></TextBlock>
            <DatePicker Grid.Column="1" Name="SaleDatePicker" HorizontalAlignment="Center" VerticalAlignment="Center" Height="30" Width="120"></DatePicker>

            <TextBlock Grid.Column="2" Text="Кол-во:" FontSize="20" VerticalAlignment="Top" Margin="16,0,0,0"></TextBlock>
            <TextBox Grid.Column="2" Height="25" Width="90" Name="ProductCount"></TextBox>
            <Button Grid.Column="3" Content="Добавить" Name="AddButton" Click="AddButton_Click"></Button>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Товар" FontSize="20" HorizontalAlignment="Center"></TextBlock>
            <TextBlock Grid.Column="1" Text="Дата продажи" FontSize="20" HorizontalAlignment="Center"></TextBlock>
            <TextBlock Grid.Column="2" Text="Количество" FontSize="20" HorizontalAlignment="Center"></TextBlock>
        </Grid>
        <Grid Grid.Row="2">
            <ListView Name="SalesListView">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Black" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="370"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Product.Title}" FontSize="15" HorizontalAlignment="Left" Margin="5"></TextBlock>
                                <TextBlock Grid.Column="1" Text="{Binding SaleDate, StringFormat=dd.MM.yyyy}" FontSize="15" HorizontalAlignment="Left" Margin="5"></TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ProductCount}" FontSize="15" HorizontalAlignment="Center" Margin="5"></TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        <Button Grid.Row="3" Content="Удалить" Name="SaleDeleteButton" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Background="Red"
                Click="SaleDeleteButton_Click"></Button>
    </Grid>
</Window>
